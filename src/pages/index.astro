---
import { getAllSiteData } from '../sanity/client';
import { FB } from '../sanity/fallback';

let sd: any = {};
try { sd = await getAllSiteData(); } catch(e) { /* fallback */ }

const G   = sd.global_       || FB.global_;
const NAV = sd.nav            || FB.nav;
const FT  = sd.footer_        || FB.footer_;
const H   = sd.hero           || FB.hero;
const SU  = sd.sectionUniverses  || FB.sectionUniverses;
const SO  = sd.sectionOnglerie   || FB.sectionOnglerie;
const SP  = sd.sectionPedicure   || FB.sectionPedicure;
const SC  = sd.sectionCoiffure   || FB.sectionCoiffure;
const SA  = sd.sectionAbout      || FB.sectionAbout;
const SS  = sd.sectionSalon      || FB.sectionSalon;
const SR  = sd.sectionReviews    || FB.sectionReviews;
const SG  = sd.sectionGallery    || FB.sectionGallery;
const SF  = sd.sectionFaq        || FB.sectionFaq;
const SRES = sd.sectionReservation || FB.sectionReservation;
const SCON = sd.sectionContact   || FB.sectionContact;
const HOR = sd.horaires          || FB.horaires;

const allP = sd.prestations?.length ? sd.prestations : null;
const ongP = allP ? allP.filter((p:any)=>p.categorie==='onglerie') : FB.prestations.onglerie;
const pedP = allP ? allP.filter((p:any)=>p.categorie==='pedicure') : FB.prestations.pedicure;
const coiP = allP ? allP.filter((p:any)=>p.categorie==='coiffure') : FB.prestations.coiffure;
const avisData = sd.avis?.length ? sd.avis : FB.avis;
const faqData  = sd.faqs?.length ? sd.faqs : FB.faqs;

// Slides avis groupés par 2
const avisSlides: any[][] = [];
for(let i=0; i<avisData.length; i+=2) avisSlides.push(avisData.slice(i,i+2));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>

<html lang="fr">

<head>

  <meta charset="UTF-8" />

  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{G.meta_title || `${G.nom} — ${G.tagline}`}</title>

  <meta name="description" content="Institut Lyne Beauty en Vieille-Ville de Fribourg. Onglerie, pédicure spa et coiffure afro & tresses. 18 ans d'expertise pour vous sublimer. Réservez votre rendez-vous." />

  <meta name="keywords" content="Onglerie Fribourg, Institut Lyne Beauty, Pose de gel Fribourg, Coiffure Fribourg, Tresses Fribourg" />

  <meta name="robots" content="index, follow" />

  <link rel="icon" type="image/webp" href={`${base}/img/logo-lyne.webp`}>
  <link rel="apple-touch-icon" href={`${base}/img/logo-lyne.webp`}>

  <link rel="canonical" href="https://lynebeauty.ch/" />

  <link rel="preload" as="image" href={`${base}/img/hero1.webp`} type="image/webp" fetchpriority="high">

  <meta property="og:type" content="business.business" />

  <meta property="og:title" content={`${G.nom} — Fribourg`} />

  <meta property="og:description" content={G.meta_desc} />

  <meta property="og:locale" content="fr_CH" />

  <link href="https://meetings.brevo.com/assets/styles/popup.css" rel="stylesheet" />

  <script src="https://meetings.brevo.com/assets/libs/popup.min.js" type="text/javascript" defer></script>

  <link rel="preconnect" href="https://fonts.googleapis.com">

  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet">

  <style is:global>

    :root{--bg:#FFFFFF;--bg-pure:#FFFFFF;--bg-warm:#F5EDE6;--bg-rose:#F2D9D1;--ink:#1A1614;--ink-soft:#4A413C;--ink-mute:#8A7E76;--signature:#D9796E;--signature-deep:#B85A4F;--gold:#C9A961;--gold-light:#E5D2A0;--line:#E8DED5;--ff-display:'Playfair Display',serif;--ff-body:'Montserrat',sans-serif;--radius-img:12px;--radius-card:16px;--shadow-soft:0 4px 30px rgba(26,22,20,.06);--shadow-deep:0 30px 80px rgba(26,22,20,.12);--t-fast:.3s cubic-bezier(.4,0,.2,1);--t-med:.6s cubic-bezier(.25,.46,.45,.94);--t-slow:1.2s cubic-bezier(.16,1,.3,1)}

    *{margin:0;padding:0;box-sizing:border-box}html{scroll-behavior:smooth}body{font-family:var(--ff-body);font-weight:300;font-size:18px;line-height:1.6;color:var(--ink);background:var(--bg);overflow-x:hidden;-webkit-font-smoothing:antialiased}img{max-width:100%;display:block;height:auto}a{color:inherit;text-decoration:none;transition:color var(--t-fast)}button{font-family:inherit;cursor:pointer;border:none;background:none}::selection{background:var(--signature);color:#fff}

    .text-link{color:var(--signature-deep);border-bottom:1px solid var(--line);font-weight:400;transition:all var(--t-fast)}.text-link:hover{color:var(--signature);border-bottom-color:var(--signature)}

    h1,h2,h3,h4{font-family:var(--ff-display);font-weight:400;letter-spacing:-.01em;color:var(--ink)}

    .eyebrow{font-family:var(--ff-body);font-size:11px;font-weight:500;letter-spacing:.32em;text-transform:uppercase;color:var(--signature);display:inline-flex;align-items:center;gap:12px}.eyebrow::before{content:'';width:32px;height:1px;background:var(--signature)}

    .section-title{font-size:clamp(2.5rem,5.5vw,4.5rem);line-height:1.05;font-weight:300;letter-spacing:-.02em}.section-title em{font-style:italic;font-weight:300;color:var(--signature)}

    .container{width:100%;max-width:1380px;margin:0 auto;padding:0 32px}section{position:relative}

    .promo-banner{background:var(--ink);color:var(--gold-light);text-align:center;padding:10px 20px;font-size:12px;letter-spacing:.08em;position:absolute;top:0;left:0;width:100%;z-index:101;font-family:var(--ff-body)}.promo-banner strong{font-weight:600;color:#fff}

    .nav{position:fixed;top:38px;left:0;right:0;z-index:100;padding:22px 0;transition:all var(--t-med);background:transparent}.nav.scrolled{top:0;background:rgba(255,255,255,.95);backdrop-filter:blur(20px);padding:14px 0;border-bottom:1px solid var(--line)}

    .nav-inner{display:flex;justify-content:space-between;align-items:center;width:100%;max-width:1380px;margin:0 auto;padding:0 20px;gap:24px;flex-wrap:nowrap}

    .mobile-cta-wrapper{display:none}

    .logo{font-family:var(--ff-display);font-size:28px;font-weight:400;letter-spacing:.04em;display:flex;align-items:center;gap:15px;text-decoration:none;color:inherit;flex-shrink:0;white-space:nowrap}.logo img{height:60px;width:auto;display:block}.logo em{font-style:italic;color:var(--signature)}

    .nav-links{display:flex;align-items:center;gap:40px;list-style:none;flex-shrink:0}.nav-links a{font-size:13px;font-weight:400;letter-spacing:.08em;text-transform:uppercase;position:relative;padding:4px 0;white-space:nowrap}.nav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--signature);transition:width var(--t-fast)}.nav-links a:hover::after{width:100%}

    .nav-cta{background:var(--signature);color:var(--bg-pure);padding:12px 24px;font-size:12px;letter-spacing:.16em;text-transform:uppercase;font-weight:500;border-radius:100px;transition:all var(--t-fast);cursor:pointer}.nav-cta:hover{background:var(--signature-deep);transform:translateY(-2px)}
    .nav-cta-icon{display:none;background:var(--signature);color:var(--bg-pure);width:40px;height:40px;border-radius:50%;align-items:center;justify-content:center;transition:all var(--t-fast);flex-shrink:0}.nav-cta-icon:hover{background:var(--signature-deep);transform:translateY(-2px)}

    .burger{display:none;width:28px;height:20px;position:relative}.burger span{position:absolute;width:100%;height:1px;background:var(--ink);transition:all var(--t-fast)}.burger span:nth-child(1){top:4px}.burger span:nth-child(2){top:50%}.burger span:nth-child(3){bottom:4px}.burger.open span:nth-child(1){top:50%;transform:rotate(45deg)}.burger.open span:nth-child(2){opacity:0}.burger.open span:nth-child(3){bottom:auto;top:50%;transform:rotate(-45deg)}

    .hero{min-height:100vh;display:grid;grid-template-columns:1.1fr 1fr;grid-template-rows:1fr auto;align-items:center;padding:140px 0 0;position:relative;overflow:hidden}.hero::before{content:'';position:absolute;top:20%;right:-10%;width:600px;height:600px;background:radial-gradient(circle,var(--bg-rose) 0%,transparent 70%);filter:blur(60px);opacity:.5;z-index:-1}

    .hero-content{padding:0 32px 0 80px;max-width:720px;animation:fadeInUp 1.2s var(--t-slow) both}.hero-eyebrow{margin-bottom:32px}

    .hero h1{font-size:clamp(2rem,4vw,3.5rem);line-height:1.15;font-weight:300;letter-spacing:-.02em;margin-bottom:24px}.hero h1 em{font-style:italic;font-weight:300;color:var(--signature);display:block}

    .hero h2{font-family:var(--ff-body);font-size:clamp(1rem,1.5vw,1.15rem);font-weight:300;color:var(--ink-soft);line-height:1.7;max-width:580px;margin-bottom:40px}

    .hero-ctas{display:flex;gap:16px;flex-wrap:wrap;align-items:center}

    .reviews-dots { display: flex; justify-content: center; gap: 10px; margin-top: 40px; }

    .dot { width: 8px; height: 8px; background: rgba(255,255,255,0.2); border-radius: 50%; transition: all var(--t-fast); cursor: pointer; }

    .dot.active { background: var(--signature); width: 28px; border-radius: 4px; }

    p a,h2 a,h3 a{color:var(--signature-deep);border-bottom:1px solid var(--line);font-weight:400;transition:all var(--t-fast)}p a:hover,h2 a:hover,h3 a:hover{color:var(--signature);border-bottom-color:var(--signature)}

    .btn{display:inline-flex;justify-content:center;align-items:center;gap:12px;padding:18px 32px;font-size:12px;letter-spacing:.16em;text-transform:uppercase;font-weight:500;border-radius:100px;transition:all var(--t-fast);cursor:pointer;border:1px solid transparent;text-align:center}

    .btn-primary{background:var(--ink);color:var(--bg-pure)}.btn-primary:hover{background:var(--signature);transform:translateY(-3px);box-shadow:0 12px 30px rgba(217,121,110,.3)}

    .btn-ghost{background:transparent;color:var(--ink);border-color:var(--ink)}.btn-ghost:hover{background:var(--ink);color:var(--bg-pure)}

    .btn .arrow{width:16px;height:1px;background:currentColor;position:relative}.btn .arrow::after{content:'';position:absolute;right:0;top:-3px;width:7px;height:7px;border-top:1px solid currentColor;border-right:1px solid currentColor;transform:rotate(45deg)}

    .hero-visual{position:relative;height:70vh;min-height:560px;padding-right:32px;animation:fadeIn 1.5s var(--t-slow) both}

    .hero-frame{width:100%;height:100%;border-radius:var(--radius-card);overflow:hidden;position:relative;box-shadow:var(--shadow-deep);background-color:var(--bg-warm)}

    .hero-frame.fade-carousel img{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;opacity:0;transform:scale(1.02);transition:opacity 1s ease-in-out,transform 8s ease;z-index:0}.hero-frame.fade-carousel img.active{opacity:1;z-index:1}.hero:hover .hero-frame.fade-carousel img.active{transform:scale(1.08)}

    .hero-badge{position:absolute;bottom:24px;left:24px;background:var(--bg-pure);padding:14px 22px;border-radius:100px;box-shadow:var(--shadow-soft);display:flex;align-items:center;gap:12px;font-size:12px;font-weight:500;letter-spacing:.04em;z-index:2}

    .hero-badge .pulse{width:8px;height:8px;background:#4ade80;border-radius:50%;position:relative}.hero-badge .pulse::after{content:'';position:absolute;inset:-4px;border-radius:50%;background:#4ade80;opacity:.4;animation:pulse 2s infinite}

    .hero-marquee{margin-top:24px;overflow:hidden;border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:14px 0;grid-column:1/-1;width:100%}

    .marquee-track{display:flex;gap:60px;white-space:nowrap;animation:marquee 35s linear infinite;font-family:var(--ff-display);font-style:italic;font-size:18px;color:var(--ink-soft);width:max-content}

    .marquee-track>span{display:inline-flex;align-items:center;gap:60px;padding-right:60px}.marquee-track .star{color:var(--signature);font-style:normal}

    .service-detail{padding:140px 0;position:relative;overflow:hidden}.service-detail.alt{background:var(--bg-warm)}

    .service-hero{display:grid;grid-template-columns:1fr 1.05fr;gap:80px;align-items:center;margin-bottom:100px}

    .service-detail.alt .service-hero{direction:rtl}.service-detail.alt .service-hero>*{direction:ltr}

    .service-img{position:relative;width:100%;aspect-ratio:4/5;border-radius:var(--radius-card);overflow:hidden;box-shadow:var(--shadow-deep);max-width:420px;margin:0 auto}

    .service-img.fade-carousel img{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity 1s ease-in-out;z-index:0}.service-img.fade-carousel img.active{opacity:1;z-index:1}

    .service-img-tag{position:absolute;top:24px;left:24px;background:rgba(255,255,255,.95);backdrop-filter:blur(10px);padding:10px 18px;border-radius:100px;font-size:11px;letter-spacing:.2em;text-transform:uppercase;font-weight:500;z-index:2}

    .service-text .eyebrow{margin-bottom:24px}.service-text h2{font-size:clamp(2.5rem,5vw,4rem);line-height:1.05;font-weight:300;margin-bottom:28px}.service-text h2 em{font-style:italic;color:var(--signature)}.service-text .lead{font-size:17px;line-height:1.7;color:var(--ink-soft);margin-bottom:24px}.service-text p{font-size:15px;line-height:1.8;color:var(--ink-soft);margin-bottom:16px}

    .service-steps{margin-top:24px;list-style:none;padding:0}.service-steps li{font-size:15px;color:var(--ink-soft);margin-bottom:12px;line-height:1.7;position:relative;padding-left:20px}.service-steps li strong{color:var(--ink);font-weight:500;margin-right:5px}.service-steps li::before{content:'✦';color:var(--signature);font-size:12px;position:absolute;left:0;top:2px}

    .pricing-block{background:var(--bg-pure);border:1px solid var(--line);border-top:3px solid var(--signature);padding:60px;border-radius:8px;position:relative}.service-detail.alt .pricing-block{background:var(--bg)}

    .pricing-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:48px;padding-bottom:24px;border-bottom:1px solid var(--line);flex-wrap:wrap;gap:20px}.pricing-header h3{font-size:32px;font-weight:400;font-style:italic}.pricing-note{font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-mute)}

    .pricing-filters{display:flex;gap:12px;margin-bottom:32px;flex-wrap:wrap}.filter-btn{padding:10px 20px;border:1px solid var(--line);border-radius:100px;font-size:13px;font-weight:500;color:var(--ink-soft);transition:all var(--t-fast)}.filter-btn:hover{border-color:var(--signature);color:var(--signature)}.filter-btn.active{background:var(--signature);border-color:var(--signature);color:var(--bg-pure)}

    .pricing-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:0 60px}

    .pricing-subtitle{grid-column:1/-1;font-family:var(--ff-display);font-style:italic;font-size:22px;margin:32px 0 16px;padding-top:24px;border-top:1px solid var(--line);color:var(--ink)}

    .price-row{display:flex;align-items:baseline;padding:18px 12px;border-bottom:1px dotted var(--line);gap:16px;transition:all var(--t-fast);border-radius:6px;cursor:pointer}.price-row:last-child{border-bottom:none}.price-row:hover{background-color:var(--bg-warm);transform:translateX(4px);border-bottom-color:transparent}

    .price-row .name{font-family:var(--ff-display);font-size:19px;font-weight:400;flex:1;letter-spacing:.01em}.price-row .name small{font-family:var(--ff-body);font-size:12px;font-weight:300;color:var(--ink-mute);display:block;margin-top:2px}

    .price-row .dots{flex:0 1 auto;border-bottom:1px dotted var(--ink-mute);height:1em;min-width:20px}.price-row .price{font-family:var(--ff-display);font-size:22px;font-weight:500;color:var(--signature);white-space:nowrap;display:flex;align-items:center}

    .price-row.hidden{display:none!important}

    .service-cta{margin-top:48px;display:flex;gap:16px;flex-wrap:wrap}

    .about{padding:140px 0;background:var(--bg-warm);position:relative;overflow:hidden}

    .about-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:100px;align-items:center}

    .about-image{position:relative;max-width:500px;margin:0 auto;width:100%}.about-image .main{position:relative;width:100%;aspect-ratio:4/5;border-radius:var(--radius-card);overflow:hidden;box-shadow:var(--shadow-deep)}

    .about-image.fade-carousel .main img{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity 1s ease-in-out;z-index:0}.about-image.fade-carousel .main img.active{opacity:1;z-index:1}

    .about-image .badge-circle{position:absolute;bottom:24px;right:24px;width:150px;height:150px;background:var(--ink);color:var(--bg-pure);border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;box-shadow:0 12px 30px rgba(0,0,0,.2);z-index:2}

    .about-image .badge-circle .num{font-size:44px;line-height:1;color:var(--signature);font-family:var(--ff-display);font-style:italic}.about-image .badge-circle .lbl{font-family:var(--ff-body);font-size:9px;letter-spacing:.2em;text-transform:uppercase;margin-top:6px;padding:0 12px}

    .about-content .eyebrow{margin-bottom:28px}.about-content h2{margin-bottom:36px}.about-content .lead{font-family:var(--ff-display);font-size:22px;font-style:italic;line-height:1.5;color:var(--ink-soft);margin-bottom:28px;font-weight:300}.about-content p{font-size:16px;line-height:1.8;color:var(--ink-soft);margin-bottom:20px}.about-content .signature{margin-top:36px;font-family:var(--ff-display);font-style:italic;font-size:24px;color:var(--signature)}

    .about-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;margin-top:48px;padding-top:36px;border-top:1px solid var(--line)}.stat-num{font-family:var(--ff-display);font-size:42px;line-height:1;color:var(--ink);font-weight:300}.stat-num em{font-style:italic;color:var(--signature)}.stat-lbl{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-mute);margin-top:8px}

    .universes{padding:140px 0;background:var(--signature);color:var(--bg-pure);position:relative;overflow:hidden}.universes::before{content:'';position:absolute;top:-50%;left:-10%;width:80%;height:200%;background:radial-gradient(ellipse,rgba(255,255,255,.08),transparent 60%);pointer-events:none}

    .universes .eyebrow{color:rgba(255,255,255,.7)}.universes .eyebrow::before{background:rgba(255,255,255,.7)}

    .universes-header{text-align:center;margin-bottom:80px;position:relative}.universes-header .eyebrow{justify-content:center;margin-bottom:24px}.universes-header .eyebrow::before{display:none}.universes-header h2{color:var(--bg-pure);font-style:italic;font-weight:300}.universes-header h2 em{color:var(--gold-light)}.universes-header h2::before{content:'✺';display:block;font-size:18px;margin-bottom:16px;color:var(--gold-light)}.universes-header p{max-width:680px;margin:24px auto 0;color:rgba(255,255,255,.85);font-size:16px;line-height:1.7}

    .universes-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:40px;max-width:1200px;margin:0 auto}

    .universe-card{text-align:center;cursor:pointer;transition:transform var(--t-med)}.universe-card:hover{transform:translateY(-12px)}

    .universe-arch{width:80%;max-width:300px;aspect-ratio:4/5;margin:0 auto 28px;border-radius:var(--radius-img);overflow:hidden;border:1px solid rgba(255,255,255,.2);position:relative}

    .universe-arch img{width:100%;height:100%;object-fit:cover;transition:transform 1s var(--t-slow)}.universe-card:hover .universe-arch img{transform:scale(1.08)}.universe-arch::after{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,transparent 50%,rgba(0,0,0,.2))}

    .universe-card h3{color:var(--bg-pure);font-size:28px;font-style:italic;font-weight:300;margin-bottom:8px}.universe-card .tagline{font-size:11px;letter-spacing:.28em;text-transform:uppercase;color:var(--gold-light);margin-bottom:16px}.universe-card .desc{color:rgba(255,255,255,.85);font-size:14px;line-height:1.7;max-width:320px;margin:0 auto 24px}

    .universe-link{display:inline-flex;align-items:center;gap:10px;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--bg-pure);border-bottom:1px solid rgba(255,255,255,.4);padding-bottom:4px;transition:all var(--t-fast)}.universe-link:hover{color:var(--gold-light);border-color:var(--gold-light)}

    .review-arrow{position:absolute;top:50%;transform:translateY(-50%);width:48px;height:48px;background:var(--bg-pure);color:var(--ink);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;z-index:10;transition:all var(--t-fast);box-shadow:var(--shadow-soft);cursor:pointer}.review-arrow:hover{background:var(--signature);color:var(--bg-pure)}.review-arrow.prev{left:10px}.review-arrow.next{right:10px}

    .reviews{padding:140px 0;background:var(--ink);color:var(--bg-pure);position:relative;overflow:hidden}.reviews-header{text-align:center;margin-bottom:70px}.reviews-header .eyebrow{color:var(--gold-light);justify-content:center}.reviews-header .eyebrow::before{background:var(--gold-light)}.reviews-header h2{color:var(--bg-pure);font-style:italic;font-weight:300}.reviews-header h2 em{color:var(--signature)}

    .reviews-rating{display:inline-flex;align-items:center;gap:14px;margin-top:20px;font-size:13px;color:rgba(255,255,255,.7)}.stars{display:inline-flex;gap:3px;color:var(--gold);font-size:16px}

    .reviews-carousel{position:relative;max-width:1200px;margin:0 auto;overflow:hidden}.reviews-track{display:flex;transition:transform .9s cubic-bezier(.65,0,.35,1)}.review-slide{min-width:100%;display:flex;justify-content:center;gap:32px;padding:0 20px}

    .review-card{flex:1 1 calc(50% - 16px);max-width:calc(50% - 16px);width:100%;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);padding:40px;border-radius:8px;transition:all var(--t-fast);backdrop-filter:blur(10px)}.review-card:hover{background:rgba(255,255,255,.07);border-color:var(--signature);transform:translateY(-4px)}

    .review-stars{color:var(--gold);font-size:14px;letter-spacing:2px;margin-bottom:20px}.review-text{font-family:var(--ff-display);font-size:19px;line-height:1.55;font-style:italic;color:rgba(255,255,255,.92);font-weight:300;margin-bottom:28px}

    .review-author{display:flex;align-items:center;gap:14px;padding-top:20px;border-top:1px solid rgba(255,255,255,.1)}.review-avatar{width:44px;height:44px;border-radius:50%;background:var(--signature);display:flex;align-items:center;justify-content:center;font-family:var(--ff-display);font-size:18px;font-style:italic;color:var(--bg-pure)}.review-meta strong{display:block;font-size:14px;font-weight:500}.review-meta span{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.5);margin-top:2px;display:inline-block}

    .reviews-dots{display:flex;justify-content:center;gap:10px;margin-top:40px}.dot{width:8px;height:8px;background:rgba(255,255,255,.2);border-radius:50%;transition:all var(--t-fast);cursor:pointer}.dot.active{background:var(--signature);width:28px;border-radius:4px}

    .gallery{padding:140px 0}.gallery-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:60px;flex-wrap:wrap;gap:24px}.gallery-header h2{font-size:clamp(2.2rem,4.5vw,3.5rem);font-weight:300;line-height:1.05}.gallery-header h2 em{font-style:italic;color:var(--signature)}.gallery-handle{font-family:var(--ff-display);font-style:italic;font-size:18px;color:var(--ink-soft)}

    .gallery-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}.gallery-grid>a{position:relative;overflow:hidden;border-radius:var(--radius-img);display:block;background:var(--bg-warm);aspect-ratio:4/5}.gallery-grid img{width:100%;height:100%;object-fit:cover;transition:transform .8s var(--t-slow)}

    .insta-overlay{position:absolute;inset:0;background:linear-gradient(135deg,transparent 40%,rgba(217,121,110,.4));opacity:0;transition:opacity var(--t-fast);display:flex;align-items:center;justify-content:center}.insta-overlay svg{width:48px;height:48px;color:var(--bg-pure);opacity:0;transform:translateY(20px);transition:all var(--t-med)}.gallery-grid>a:hover img{transform:scale(1.06)}.gallery-grid>a:hover .insta-overlay{opacity:1}.gallery-grid>a:hover .insta-overlay svg{opacity:1;transform:translateY(0)}

    .faq{padding:140px 0;background:var(--bg-pure)}.faq-grid{display:grid;grid-template-columns:1fr 1.4fr;gap:80px;align-items:flex-start}.faq-aside{position:sticky;top:120px}.faq-aside h2{margin-bottom:24px}.faq-aside h2 em{color:var(--signature);font-style:italic}.faq-aside p{color:var(--ink-soft);margin-bottom:32px;line-height:1.7}

    .faq-item{border-bottom:1px solid var(--line);padding:28px 0}.faq-item:first-child{border-top:1px solid var(--line)}.faq-question{display:flex;justify-content:space-between;align-items:center;width:100%;text-align:left;font-family:var(--ff-display);font-size:22px;font-weight:400;color:var(--ink);cursor:pointer;gap:24px;transition:color var(--t-fast)}.faq-question:hover{color:var(--signature)}

    .faq-toggle{width:36px;height:36px;border-radius:50%;background:var(--bg-pure);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all var(--t-fast);position:relative}.faq-toggle::before,.faq-toggle::after{content:'';position:absolute;background:var(--ink);transition:transform var(--t-fast)}.faq-toggle::before{width:12px;height:1px}.faq-toggle::after{width:1px;height:12px}

    .faq-item.open .faq-toggle{background:var(--signature);border-color:var(--signature)}.faq-item.open .faq-toggle::before,.faq-item.open .faq-toggle::after{background:var(--bg-pure)}.faq-item.open .faq-toggle::after{transform:rotate(90deg)}

    .faq-answer{max-height:0;overflow:hidden;padding-top:0;transition:max-height .4s cubic-bezier(0,1,0,1),padding-top .4s ease}.faq-item.open .faq-answer{max-height:1000px;padding-top:20px;transition:max-height .6s ease-in-out,padding-top .4s ease}.faq-answer p{color:var(--ink-soft);line-height:1.7;font-size:15px}

    .contact{padding:140px 0;position:relative}.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}.contact-info h2{margin-bottom:32px}.contact-info h2 em{color:var(--signature);font-style:italic}.contact-info .lead{font-family:var(--ff-display);font-style:italic;font-size:22px;line-height:1.5;color:var(--ink-soft);margin-bottom:40px}

    .contact-item{display:flex;gap:18px;padding:22px 0;border-bottom:1px solid var(--line)}.contact-item:last-child{border:none}.contact-icon{width:44px;height:44px;border-radius:50%;background:var(--bg-warm);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--signature)}.contact-icon svg{width:18px;height:18px}.contact-detail .label{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:4px}.contact-detail .value{font-family:var(--ff-display);font-size:19px;color:var(--ink)}

    .contact-hours{background:var(--bg-warm);padding:48px;border-radius:16px;position:relative;overflow:hidden}.contact-hours h3{font-size:28px;font-style:italic;margin-bottom:32px;position:relative}

    .hours-row{display:flex;justify-content:space-between;padding:16px 0;border-bottom:1px dotted var(--line);position:relative}.hours-row:last-of-type{border:none}.hours-row .day{font-weight:500;font-size:14px;letter-spacing:.04em}.hours-row .time{font-family:var(--ff-display);font-size:17px;color:var(--ink-soft)}.hours-row.closed .time{color:var(--signature);font-style:italic}

    .map-wrap{margin-top:100px;border-radius:16px;overflow:hidden;height:420px;box-shadow:var(--shadow-soft);filter:grayscale(.3) contrast(1.05)}.map-wrap iframe{width:100%;height:100%;border:none}

    .reservation-section{padding:140px 0;background:var(--bg-warm)}.reservation-container{max-width:900px;margin:0 auto;background:var(--bg-pure);padding:60px;border-radius:var(--radius-card);box-shadow:var(--shadow-deep)}.reservation-header{text-align:center;margin-bottom:40px}.reservation-header h2{font-size:3rem;margin-bottom:16px}

    .modal{position:fixed;inset:0;background:rgba(26,22,20,.7);backdrop-filter:blur(8px);z-index:200;opacity:0;visibility:hidden;transition:all var(--t-med);display:flex;align-items:center;justify-content:center;padding:20px}.modal.open{opacity:1;visibility:visible}.modal-content{background:var(--bg);max-width:880px;width:100%;max-height:90vh;overflow-y:auto;border-radius:16px;padding:60px;position:relative;transform:scale(.95);transition:transform var(--t-med)}.modal.open .modal-content{transform:scale(1)}.modal-close{position:absolute;top:24px;right:24px;width:44px;height:44px;border-radius:50%;background:var(--bg-warm);display:flex;align-items:center;justify-content:center;font-size:20px;color:var(--ink);transition:all var(--t-fast);cursor:pointer}.modal-close:hover{background:var(--signature);color:white;transform:rotate(90deg)}

    footer{background:var(--ink);color:var(--bg-pure);padding:80px 0 32px;position:relative}.footer-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:60px;margin-bottom:60px}.footer-brand .logo{display:flex;align-items:center;justify-content:flex-start;gap:12px;text-decoration:none;color:var(--bg-pure);font-family:var(--ff-display);font-size:24px;margin-bottom:20px}.footer-brand .logo img{height:50px;width:auto;display:block}.footer-brand .logo em{font-style:italic;color:var(--signature)}.footer-brand p{color:rgba(255,255,255,.6);font-size:14px;line-height:1.7;max-width:320px}

    footer h4{color:var(--bg-pure);font-size:14px;letter-spacing:.16em;text-transform:uppercase;font-family:var(--ff-body);font-weight:500;margin-bottom:24px}footer ul{list-style:none}footer ul li{margin-bottom:12px}footer ul a{color:rgba(255,255,255,.6);font-size:14px}footer ul a:hover{color:var(--signature)}

    .social-links{display:flex;gap:12px;margin-top:20px}.social-links a{width:40px;height:40px;border-radius:50%;border:1px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;transition:all var(--t-fast)}.social-links a:hover{background:var(--signature);border-color:var(--signature);transform:translateY(-2px)}.social-links svg{width:16px;height:16px}

    .footer-bottom{padding-top:32px;border-top:1px solid rgba(255,255,255,.1);display:flex;justify-content:space-between;flex-wrap:wrap;gap:16px;font-size:12px;color:rgba(255,255,255,.5);letter-spacing:.04em}

    .whatsapp-float{position:fixed;bottom:28px;right:28px;width:60px;height:60px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;z-index:99;box-shadow:0 12px 30px rgba(37,211,102,.4);transition:all var(--t-fast);animation:floatYsimple 3s ease-in-out infinite}.whatsapp-float:hover{transform:scale(1.1)}.whatsapp-float svg{width:30px;height:30px;fill:white}

    @keyframes fadeInUp{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}@keyframes fadeIn{from{opacity:0}to{opacity:1}}@keyframes pulse{0%{transform:scale(1);opacity:.5}100%{transform:scale(2.5);opacity:0}}@keyframes floatYsimple{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

    .reveal{opacity:0;transform:translateY(30px);transition:opacity .5s ease-out,transform .5s ease-out}.reveal.visible{opacity:1;transform:translateY(0)}

    @media(max-width:1100px){.hero{grid-template-columns:1fr;grid-template-rows:auto auto auto;padding-top:160px}.hero-visual{height:60vh;min-height:480px;padding:0 32px;margin-top:60px}.about-grid,.faq-grid,.contact-grid{grid-template-columns:1fr;gap:60px}.service-hero{grid-template-columns:1fr;gap:50px}.service-detail.alt .service-hero{direction:ltr}.faq-aside{position:static}.footer-grid{grid-template-columns:1fr 1fr;gap:40px}.universes-grid{grid-template-columns:1fr;gap:40px}.about-stats{gap:20px}.nav-links{gap:24px}.nav-links a{font-size:12px}}

    @media(max-width:980px){.nav-links{position:fixed;top:0;right:-100%;width:80%;height:100vh;background:var(--bg);flex-direction:column;justify-content:center;gap:32px;transition:right var(--t-med);box-shadow:var(--shadow-deep);padding:40px;z-index:101}.nav-links.open{right:0}.burger{display:block;z-index:102}.nav-cta{display:none}.nav-cta-icon{display:flex}}

    @media(max-width:768px){.container{padding:0 20px}.nav-links{position:fixed;top:0;right:-100%;width:80%;height:100vh;background:var(--bg);flex-direction:column;justify-content:center;gap:32px;transition:right var(--t-med);box-shadow:var(--shadow-deep);padding:40px}.nav-links.open{right:0}.burger{display:block;z-index:102}.nav-cta{display:none}.nav-cta-icon{display:flex}.hero h1{font-size:2rem}.hero-content{padding:0 20px}.hero-visual{height:auto;aspect-ratio:4/5;min-height:unset;margin-top:40px;padding:0}.btn{width:100%;justify-content:center}.nav-inner{padding:0 24px}.mobile-cta-wrapper{display:block;margin-top:24px;width:100%}.mobile-cta-wrapper .btn{width:100%;justify-content:center}.pricing-block{padding:32px 24px}.pricing-grid{grid-template-columns:1fr;gap:0}.price-row{flex-direction:column;gap:8px;border-bottom:1px solid var(--line);padding:20px 0}.price-row .dots{display:none}.price-row .price{font-size:20px;align-self:flex-start}.universes-grid{grid-template-columns:1fr;gap:50px}.about-stats{grid-template-columns:1fr;gap:32px;text-align:center}.review-slide{flex-direction:column;gap:20px;padding:0 8px}.review-card{max-width:100%;padding:28px}.reviews-carousel{padding-bottom:70px}.review-arrow{top:auto;bottom:0;transform:none;width:44px;height:44px}.review-arrow.prev{left:25%}.review-arrow.next{right:25%}.reviews-dots{position:absolute;bottom:18px;left:50%;transform:translateX(-50%);margin-top:0}.gallery-grid{grid-template-columns:1fr 1fr;gap:12px}.reservation-container{padding:32px 20px}.footer-grid{grid-template-columns:1fr;gap:40px}.modal-content{padding:40px 24px;margin-top:30px}.contact-hours{padding:32px 24px}.promo-banner{position:absolute;font-size:11px;padding:10px}.nav{padding:12px 0;position:fixed;top:54px}.nav.scrolled{padding:12px 0;position:fixed;top:0}.logo{font-size:22px}.logo img{height:40px}section{padding:80px 0}.hero{padding-top:180px}}

  </style>
  <script define:vars={{agendaPrestations: {
    'premiere-pose-gel':'https://meet.brevo.com/institut-lynebeauty/premiere-pose-gel/',
    'remplissage-gel-4-5-sem':'https://meet.brevo.com/institut-lynebeauty/remplissage-gel-4-5-sem/',
    'remplissage-acrylique-4-5-sem':'https://meet.brevo.com/institut-lynebeauty/premiere-pose-gel-copie',
    'remplissage-gel-tardif-6-sem':'https://meet.brevo.com/institut-lynebeauty/remplissage-acrylique-tardif-6-sem',
    'premiere-pose-acrylique':'https://meet.brevo.com/institut-lynebeauty/premiere-pose-acrylique/',
    'remplissage-acrylique-tardif-6-sem':'https://meet.brevo.com/institut-lynebeauty/remplissage-gel-tardif-6-sem',
    'manucure-simple':'https://meet.brevo.com/institut-lynebeauty/manucure-simple/',
    'vernis-semi-permanent-mains':'https://meet.brevo.com/institut-lynebeauty/vernis-semi-permanent-mains',
    'gel-acrylique-pieds':'https://meet.brevo.com/institut-lynebeauty/pedicure-gel-ou-acrylique-pieds',
    'pedicure-spa-simple':'https://meet.brevo.com/institut-lynebeauty/onglerie-manucure-simple-copy',
    'pedicure-spa-semi-permanent':'https://meet.brevo.com/institut-lynebeauty/pedicure-pedicure-spa-semi-permanent/',
    'pedicure-gel-acrylique':'https://meet.brevo.com/institut-lynebeauty/pedicure-pedicure-spa-simple-copy',
    'vernis-semi-permanent-pieds':'https://meet.brevo.com/institut-lynebeauty/pedicure-vernis-semi-permanent-pieds-45-chf',
    'barrels-twists':'https://meet.brevo.com/institut-lynebeauty/coiffure-barrels-twists-fribourg-des-100-chf',
    'deux-tresses-sans':'https://meet.brevo.com/institut-lynebeauty/coiffure-2-grandes-tresses-plaquees-sans-extension-des-45-chf',
    'deux-tresses-ext':'https://meet.brevo.com/institut-lynebeauty/coiffure-2-grandes-tresses-plaquees-sans-extension-des-45-chf',
    'couleur-racine':'https://meet.brevo.com/institut-lynebeauty/coiffure-coloration-racines-fribourg-des-60-chf',
    'brushing':'https://meet.brevo.com/institut-lynebeauty/coiffure-brushing-des-50-chf',
    'shampooing':'https://meet.brevo.com/institut-lynebeauty/coiffure-shampooing-des-20-chf',
    'tresses-draid':'https://meet.brevo.com/institut-lynebeauty/tresses-draid-avec-extensions/',
    'tresses-plaquees':'https://meet.brevo.com/institut-lynebeauty/coiffure-tresses-plaquees/',
    'tresses-plaquees-avec-ext':'https://meet.brevo.com/institut-lynebeauty/3coiffure-tresses-plaquees-avec-extension-des-100-chf',
    'vanilles-twists':'https://meet.brevo.com/institut-lynebeauty/coiffure-vanilles-ou-twists',
    'vanilles-twists-ext':'https://meet.brevo.com/institut-lynebeauty/3coiffure-vanilles-ou-twists-avec-extension-des-120-chf',
    'entretien-locks':'https://meet.brevo.com/institut-lynebeauty/coiffure-entretien-locks-rasta/',
    'pose-tissage':'https://meet.brevo.com/institut-lynebeauty/coiffure-pose-de-tissage-complete/',
    'chignon':'https://meet.brevo.com/institut-lynebeauty/coiffure-2-grandes-tresses-plaquees-sans-extension-des-45-chf-copie',
    'pose-perruque':'https://meet.brevo.com/institut-lynebeauty/coiffure-pose-perruque/',
