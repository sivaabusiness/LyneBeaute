<div class="modal" id="modal-onglerie"><div class="modal-content"><button class="modal-close" onclick="closeModal('modal-onglerie')">×</button><span class="eyebrow">Expertise · Univers I</span><h2>L'art de l'<em>onglerie</em> à Fribourg</h2><p>L'onglerie chez Lyne Beauty n'est pas une succession de gestes : c'est un protocole, une technique, une lecture de la main.</p><h3>Pose Gel</h3><p>Construction sur ongle naturel ou avec rallonge. Tenue moyenne : 3 à 4 semaines avant remplissage.</p><h3>Acrylique</h3><p>Rigidité supérieure, idéale pour les ongles fragiles ou les longueurs ambitieuses. Sculptée à main levée.</p><h3>Vernis semi-permanent</h3><p>Couleur impeccable pendant 2 à 3 semaines, disponible sur mains et pieds.</p><h3>Nail Art & French</h3><p>French, ombré, marbré, chrome, motifs floraux. Supplément unique de 15 CHF.</p></div></div>

<div class="modal" id="modal-pedicure"><div class="modal-content"><button class="modal-close" onclick="closeModal('modal-pedicure')">×</button><span class="eyebrow">Expertise · Univers II</span><h2>La <em>pédicure</em> Spa & Beauté</h2><div style="background:#faf5f5;color:#8a3c3c;padding:12px 16px;border-left:3px solid #d97777;margin:15px 0;font-size:14px;"><strong>Information importante :</strong> Pour des raisons médicales, l'esthéticienne ne prend pas en charge les personnes présentant des mycoses. Merci de vous orienter vers un podologue.</div><p>À Fribourg, je vous ouvre les portes d'un véritable sanctuaire pour vos pieds. Mon rituel pédicure est un moment de lâcher-prise conçu pour soulager vos appuis et sublimer vos ongles.</p></div></div>

<div class="modal" id="modal-coiffure"><div class="modal-content"><button class="modal-close" onclick="closeModal('modal-coiffure')">×</button><span class="eyebrow">Expertise · Univers III</span><h2>La <em>coiffure</em> afro & classique</h2><p>Tresses afro, tissages, colorations, défrisages, brushings : Lyne Beauty est l'un des rares salons de Fribourg à maîtriser pleinement ces deux univers capillaires.</p><h3>Tresses</h3><p>Plaquées, draid, rasta — simples ou élaborées. Durée : entre 2h et 5h selon le volume.</p><h3>Tissages & Perruques</h3><p>Pose cousu main, ajustement millimétré pour un rendu naturel. Entretien toutes les 6 à 8 semaines.</p><h3>Colorations</h3><p>Coloration racines, applications minutieuses avec palette professionnelle.</p></div></div>

<script>
  // Nav scroll
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => { nav?.classList.toggle('scrolled', window.scrollY > 60); });
  // Burger
  const burger = document.getElementById('burger');
  const navLinks = document.getElementById('navLinks');
  burger?.addEventListener('click', () => { burger.classList.toggle('open'); navLinks?.classList.toggle('open'); });
  navLinks?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => { burger?.classList.remove('open'); navLinks.classList.remove('open'); }));
  // FAQ
  window.toggleFaq = function(btn) { const item = btn.parentElement; const isOpen = item.classList.contains('open'); document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open')); if(!isOpen) item.classList.add('open'); };
  // Reviews carousel
  const track = document.getElementById('reviewsTrack');
  const slides = track ? track.querySelectorAll('.review-slide') : [];
  const dotsContainer = document.getElementById('reviewsDots');
  let cur = 0, iv: any;
  if(slides.length > 0) {
    slides.forEach((_,i) => { const d = document.createElement('button'); d.className = 'dot'+(i===0?' active':''); d.setAttribute('aria-label','Slide '+(i+1)); d.addEventListener('click',()=>goToSlide(i)); dotsContainer?.appendChild(d); });
    window.goToSlide = function(i) { cur=i; if(track) track.style.transform=`translateX(-${i*100}%)`; document.querySelectorAll('.dot').forEach((d,idx)=>d.classList.toggle('active',idx===i)); reset(); };
    window.nextSlide = function() { goToSlide((cur+1)%slides.length); };
    window.prevSlide = function() { goToSlide((cur-1+slides.length)%slides.length); };
    function reset() { clearInterval(iv); iv=setInterval(window.nextSlide,9000); }
    reset();
  }
  // Filtres onglerie
  window.filtrerOnglerie = function(cat, e) { document.querySelectorAll('#onglerie .filter-btn').forEach(b=>b.classList.remove('active')); e?.target?.classList.add('active'); document.querySelectorAll('#onglerie-grid .price-row, #onglerie-grid .pricing-subtitle').forEach(el => { const c = el.getAttribute('data-category'); el.classList.toggle('hidden', !(cat==='all'||c===cat||c==='all')); }); };
  // Filtres coiffure
  window.filtrerCoiffure = function(cat) { document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active')); (event as any)?.target?.classList.add('active'); document.querySelectorAll('#coiffure-grid .price-row').forEach(el => { el.classList.toggle('hidden', !(cat==='all'||el.getAttribute('data-category')===cat)); }); };
  // Modals
  window.openModal = function(id) { document.getElementById(id)?.classList.add('open'); document.body.style.overflow='hidden'; };
  window.closeModal = function(id) { document.getElementById(id)?.classList.remove('open'); document.body.style.overflow=''; };
  document.querySelectorAll('.modal').forEach(m => m.addEventListener('click', e => { if(e.target===m) window.closeModal((m as HTMLElement).id); }));
  document.addEventListener('keydown', e => { if(e.key==='Escape') document.querySelectorAll('.modal.open').forEach(m => window.closeModal((m as HTMLElement).id)); });
  // Fade carousel
  document.addEventListener('DOMContentLoaded', () => { document.querySelectorAll('.fade-carousel').forEach(c => { const imgs = c.querySelectorAll('img'); let i=0; if(imgs.length>1) setInterval(()=>{ imgs[i].classList.remove('active'); i=(i+1)%imgs.length; imgs[i].classList.add('active'); },3000); }); });
  // Reveal scroll
  const obs = new IntersectionObserver(entries => { entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('visible'); obs.unobserve(e.target); } }); },{threshold:.12,rootMargin:'0px 0px -60px 0px'});
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>

