  </script>
</head>
<body>

<div class="promo-banner" id="promoBanner" set:html={G.annonce}></div>

<nav class="nav" id="nav">
  <div class="nav-inner">
    <a href="#top" class="logo">
      <img src={`${base}/img/logo-lyne.webp`} alt={`Logo ${G.nom}`} width="140" height="140">
      <span>Institut Lyne<em>Beauty</em></span>
    </a>
    <ul class="nav-links" id="navLinks">
      {(NAV.liens || FB.nav.liens).map((l:any) => (
        <li><a href={l.ancre}>{l.label}</a></li>
      ))}
      <li class="mobile-cta-wrapper">
        <a href={G.lien_reservation} class="btn btn-primary" onclick="document.getElementById('burger').click(); reserverSoin('general'); return false;">{NAV.cta || FB.nav.cta}</a>
      </li>
    </ul>
    <a href={G.lien_reservation} onclick="reserverSoin('general'); return false;" class="nav-cta">{NAV.cta_court || 'Réserver'}</a>
    <a href={G.lien_reservation} onclick="reserverSoin('general'); return false;" class="nav-cta-icon" aria-label="Réserver">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><rect x="3" y="4" width="18" height="18" rx="3"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    </a>
    <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
</nav>

<main>

<!-- ══ HERO ═══════════════════════════════════════════════════════════════ -->
<section class="hero" id="top">
  <div class="hero-content">
    <span class="eyebrow hero-eyebrow">{H.eyebrow}</span>
    <h1>{H.h1_normal}<em>{H.h1_italic}</em>{H.h1_suite||' au cœur de Fribourg'}</h1>
    <h2 set:html={H.h2}></h2>
    <div class="hero-ctas">
      <a href={G.lien_reservation} onclick="reserverSoin('general'); return false;" class="btn btn-primary">{H.cta1} <span class="arrow"></span></a>
      <a href="#universes" class="btn btn-ghost">{H.cta2}</a>
    </div>
  </div>
  <div class="hero-visual">
    <div class="hero-frame fade-carousel">
      {(H.images || FB.hero.images).map((src:string, i:number) => (
        <img src={`${base}/${src}`} alt={`Intérieur Institut Lyne Beauty ${i+1}`} loading={i===0?'eager':'lazy'} width="800" height="1000" class={i===1?'active':''} />
      ))}
    </div>
    <div class="hero-badge"><span class="pulse"></span>{H.badge}</div>
  </div>
  <div class="hero-marquee">
    <div class="marquee-track">
      <span set:html={(H.marquee||FB.hero.marquee).split('✦').join('<span class="star">✦</span>')}></span>
      <span set:html={(H.marquee||FB.hero.marquee).split('✦').join('<span class="star">✦</span>')}></span>
    </div>
  </div>
</section>

<!-- ══ UNIVERS ════════════════════════════════════════════════════════════ -->
<section class="universes" id="universes">
  <div class="container">
    <div class="universes-header reveal">
      <span class="eyebrow">{SU.eyebrow}</span>
      <h2 class="section-title" set:html={SU.titre}></h2>
      <p set:html={SU.intro}></p>
    </div>
    <div class="universes-grid">
      {(SU.cartes||FB.sectionUniverses.cartes).map((c:any) => (
        <article class="universe-card reveal" onclick={`document.querySelector('${c.lien}').scrollIntoView({behavior:'smooth'})`}>
          <div class="universe-arch fade-carousel">
            <img src={`${base}/${c.image}`} class="active" alt={c.h3} loading="lazy" width="600" height="750" />
          </div>
          <div class="tagline">{c.tagline}</div>
          <h3>{c.h3}</h3>
          <p class="desc">{c.desc}</p>
          <a href={c.lien} class="universe-link">Découvrir <span class="arrow"></span></a>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ══ ONGLERIE ══════════════════════════════════════════════════════════ -->
<section class="service-detail" id="onglerie">
  <div class="container">
    <div class="service-hero">
      <div class="service-visual-column">
        <div class="service-img reveal fade-carousel">
          {(SO.images||FB.sectionOnglerie.images).map((src:string,i:number)=>(
            <img src={`${base}/${src}`} class={i===0?'active':''} alt={`Onglerie ${i+1}`} loading="lazy" width="600" height="750" />
          ))}
          <div class="service-img-tag">Rituel I</div>
        </div>
        <div class="reveal" style="margin-top:24px;text-align:center;">
          <a href={G.instagram} target="_blank" rel="noopener" class="btn btn-ghost" style="width:100%;justify-content:center;display:inline-flex;">{SO.insta_cta||'Voir mes modèles d\'ongles'} <span class="arrow"></span></a>
